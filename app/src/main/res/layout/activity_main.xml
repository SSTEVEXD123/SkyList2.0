<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/permissionHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/permission_required"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/songList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="280dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/permissionHint" />

    <LinearLayout
        android:id="@+id/playerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@color/purple_500"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@+id/miniPlayerRoot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:id="@+id/playerSongTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/white" android:textStyle="bold" />
        <TextView android:id="@+id/playerSongArtist" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/white" />
        <TextView android:id="@+id/lyricsLine" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/white" />
        <TextView android:id="@+id/discordStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/white" />
        <TextView android:id="@+id/recognitionStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/white" />
        <TextView android:id="@+id/listenTogetherStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/white" />

        <SeekBar android:id="@+id/seekBar" android:layout_width="match_parent" android:layout_height="wrap_content" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="horizontal">
            <ImageButton android:id="@+id/previous" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:src="@drawable/ic_previous" />
            <ImageButton android:id="@+id/playPause" android:layout_width="56dp" android:layout_height="56dp" android:background="@android:color/transparent" android:src="@drawable/ic_play" />
            <ImageButton android:id="@+id/next" android:layout_width="48dp" android:layout_height="48dp" android:background="@android:color/transparent" android:src="@drawable/ic_next" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/hostSession" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Host" />
            <Button android:id="@+id/recognizeSong" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Recognize" />
            <Button android:id="@+id/addToFavorites" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fav" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/miniPlayerRoot"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="@color/black"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/miniTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textStyle="bold" />
            <TextView android:id="@+id/miniArtist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
        </LinearLayout>

        <ImageButton android:id="@+id/miniPlayPause" android:layout_width="44dp" android:layout_height="44dp" android:background="@android:color/transparent" android:src="@drawable/ic_play" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
